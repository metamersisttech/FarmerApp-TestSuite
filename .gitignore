# =============================================================================
# FarmerApp Test Suite — .gitignore additions
# =============================================================================

# Test credentials — NEVER commit
.env.test

# Test reports (auto-generated — too large for git)
docs/testing/reports/

# Python virtual environment
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo

# Maestro temp files
maestro/.maestro/

# Screen recordings (large binary files)
*.mp4
*.mov

# Android build outputs
build/

# =============================================================================
# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment and secrets (for Django API integration)
.env
.env.local
.env.*.local
*.env

# Firebase configuration (contains sensitive keys)
# Uncomment if you want to keep these out of git
# android/app/google-services.json
# ios/Runner/GoogleService-Info.plist

# Local configuration
local.properties

# Generated files
*.g.dart
*.freezed.dart

# Plan files
*.plan.md