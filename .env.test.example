# =============================================================================
#   FarmerApp Test Suite — Test Credentials Template
#   ==================================================
#   Copy this file to .env.test and fill in values.
#   .env.test is git-ignored and should NEVER be committed.
#
#   For CI/CD, add these as GitHub Secrets:
#     Settings → Secrets → Actions → New repository secret
# =============================================================================

# Test account phone number (10 digits, no country code)
FARMERAPP_TEST_PHONE=9999999999

# Fixed OTP for the test account
# Configure your Django backend to accept a fixed test OTP
# (e.g., check TEST_OTP env var in sms_service.py when DEBUG=True)
FARMERAPP_TEST_OTP=123456

# Test account email (for email login flow)
FARMERAPP_TEST_EMAIL=test@farmerapp.com

# Test account password
FARMERAPP_TEST_PASSWORD=Test@1234

# Anthropic API key (for make triage — Claude AI crash analysis)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
